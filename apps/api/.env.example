# Railway provides this automatically when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@localhost:5432/keep"

# Generate a real secret for anything beyond local dev, e.g.: openssl rand -hex 32
JWT_SECRET="replace-this-with-a-long-random-string"

PORT=4000

# The deployed URL of apps/web, so the API only accepts requests from it.
CORS_ORIGIN="http://localhost:5173"
