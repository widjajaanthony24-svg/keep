datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  projects     Project[]
}

// mode: "creative" | "contract"
// visibility: "private" | "unlisted" | "public"  — controls the shareable blueprint link (Phase 2)
model Project {
  id            String   @id @default(cuid())
  name          String
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  buildingGraph Json
  mode          String   @default("creative")
  visibility    String   @default("private")
  shareSlug     String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
